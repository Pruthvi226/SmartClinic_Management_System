# Smart Hospital Management - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smartclinic
DB_USER=root
DB_PASSWORD=Pruthvi@2324

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Set to 'prod' for production, 'dev' for development
SPRING_PROFILES_ACTIVE=prod

# ============================================
# DOCKER CONFIGURATION (for docker-compose)
# ============================================
# These are used by docker-compose.yml
MYSQL_ROOT_PASSWORD=Pruthvi@2324
MYSQL_USER=root
MYSQL_DATABASE=smartclinic

# ============================================
# APPLICATION PORT
# ============================================
APP_PORT=8080
DB_CONTAINER_PORT=3306

# ============================================
# PRODUCTION NOTES
# ============================================
# 1. Always use strong, randomly generated passwords
# 2. Set useSSL=true for production MySQL connections
# 3. Use a secure method to manage these secrets (AWS Secrets Manager, HashiCorp Vault, etc.)
# 4. Never commit the .env file with actual credentials to version control
# 5. Use HTTPS in production for the application
